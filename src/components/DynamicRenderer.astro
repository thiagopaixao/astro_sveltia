---
const { componentList, componentMap } = Astro.props;

function renderComponents(list) {
  return list.map(({ type, components: childComponents, ...restProps }) => {
    const Component = componentMap[type];
    if (!Component) return null;
    return (
      <Component {...restProps}>
        {childComponents && renderComponents(childComponents)}
      </Component>
    );
  });
}
---

{renderComponents(componentList)}
