---
import Group from './Group.astro';
import ColumnSticky from './ColumnSticky.astro';
import Text from './Text.astro';

// Dicionário de mapeamento de componentes
const components = {
  Group,
  ColumnSticky,
  Text,
};

// Obtém o componente a ser renderizado das props
const { component } = Astro.props || {};

// Verifica se o componente existe e é válido
if (!component) {
  console.error('Component data is undefined or null.');
}

const { type, components: childComponents = [], ...props } = component || {};

// Verifica se o tipo é válido e mapeado
if (!type) {
  console.error('Component type is undefined.');
}

const Component = components[type];
if (!Component) {
  console.error(`Unknown component type: ${type}`);
}
---

{Component ? (
  <Component {...props}>
    {/* Renderiza os subcomponentes recursivamente, se existirem */}
    {childComponents.length > 0 &&
      childComponents.map((child, index) => (
        <DynamicComponent key={index} component={child} />
      ))}
  </Component>
) : (
  <p style="color: red;">Erro: Tipo de componente desconhecido ou não definido.</p>
)}
