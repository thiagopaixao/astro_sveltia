---
import Group from '../../components/Group.astro';
import Text from '../../components/Text.astro';
import ColumnSticky from '../../components/ColumnSticky.astro';

interface Props {
    sectionData: {
        layout: string;
        txtColor: string;
        bgColor: string;
        title: string;
        children?: any[];
        body: string;
    }
}

const { sectionData } = Astro.props;
const { 
    layout,
    txtColor,
    bgColor,
    title,
    children,
    body
} = sectionData;
---

<Group
    layout={layout}
    txtColor={txtColor}
    bgColor={bgColor}
    title={title}
>
    <Fragment set:html={body} />
    {children && children.map((child, index) => {
        switch (child.type) {
            case 'Text':
                return <Text key={index} sectionData={child} />;
            case 'ColumnSticky':
                return <ColumnSticky key={index} sectionData={child} />;
            default:
                return null;
        }
    })}
</Group>
