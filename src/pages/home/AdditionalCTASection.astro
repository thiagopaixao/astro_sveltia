---
// Import necessary components and assets
import CTA from '../../components/CTA.astro';
import img from '../../assets/images/group-bg.png';

// Import markdown content
const content = await import('../../content/pages/home/AdditionalCTASection.md');
const { 
    ctaText, 
    cardsArr 
} = content.frontmatter;
---

{/* Call to Action section with highlighted text and background image */}
<CTA
    layout="text"
    highlightedText="Alter do Chão Also Needs to Be Recognized"
    text={ctaText}
    link={cardsArr[0].link}
    txtColor="yellow"
    bgColor="grey"
    imgBg={img.src}
>
    <Fragment set:html={content.compiledContent()} />
</CTA>
