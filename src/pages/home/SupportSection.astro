---
// Organize imports alphabetically
import ChartBar from '../../components/ChartBar.astro';
import Column from '../../components/Column.astro';
import Group from '../../components/Group.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import InnerColumns from '../../components/InnerColumns.astro';
import LogosGroup from '../../components/LogosGroup.astro';
import Text from '../../components/Text.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';

// Import content
import * as content from '../../contents/home/SupportSection.md';

// Import images at the end
import img from '../../assets/images/group-bg.png';
import imgMap from '../../assets/images/map.png';
import logo from '../../assets/images/logo-1.jpg';
import logo2 from '../../assets/images/logo-2.png';
import logo3 from '../../assets/images/logo-3.png';

// Define logos data with consistent structure
const logos = [
    {
        image: logo,
        link: {
            url: '#',
            target: '_blank',
            title: 'Lorem Logo',
        },
    },
    {
        image: logo2,
        link: {
            url: '#',
            target: '_self',
            title: 'Ipsum dolor logo',
        },
    },
    {
        image: logo3,
        link: {
            url: '#',
            target: '_blank',
            title: 'Sit amet lorem logo',
        },
    },
];

const { chartTitle, chartNotes, chartBars, videoUrl, videoCaption, title, mainText, column1, column2, finalText, imageCaption } = content.frontmatter;
---

<Group 
    txtColor="#F0EAD9" 
    overlay="dark" 
    bgColor="#006949" 
    imgBg={img.src}
>
    <Column>
        <LogosGroup 
            title="Apoio" 
            logos={logos} 
        />

        <ChartBar
            title={chartTitle}
            notes={chartNotes}
            values={chartBars}
        />

        <VideoEmbed wide>
            <iframe
                width="560"
                height="315"
                src={videoUrl}
                title="YouTube video player"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
            ></iframe>
            <Fragment slot="caption">
                {videoCaption}
            </Fragment>
        </VideoEmbed>

        <Text>
            <h2>{title}</h2>

            <p>{mainText}</p>

            <InnerColumns>
                <Fragment slot="column-1">
                    <p>{column1}</p>
                </Fragment>
                <Fragment slot="column-2">
                    <p>{column2}</p>
                </Fragment>
            </InnerColumns>

            <p>{finalText}</p>
        </Text>

        <ImageBlock 
            src={imgMap} 
            alt="" 
            wide
        >
            {imageCaption}
        </ImageBlock>
    </Column>
</Group>
