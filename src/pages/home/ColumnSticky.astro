---
import ColumnSticky from '../../components/ColumnSticky.astro';

interface Props {
    sectionData: {
        txtColor: string;
        bgColor: string;
        title: string;
        content: string;
    }
}

const { sectionData } = Astro.props;
const { 
    txtColor,
    bgColor,
    title,
    content
} = sectionData;
---

<ColumnSticky
    txtColor={txtColor}
    bgColor={bgColor}
    title={title}
>
    <Fragment set:html={content} />
</ColumnSticky>
