---
// Import necessary components
import CTA from '../../components/CTA.astro';
import { Image } from 'astro:assets';
import { getImage } from 'astro:assets';

interface Props {
    sectionData: {
        backgroundImage: string;
        txtColor: string;
        bgColor: string;
        ctaText: string;
        link: {
            url: string;
            target: string;
            text: string;
        };
        body: string;
    }
}

const { sectionData } = Astro.props;
const { 
    backgroundImage,
    txtColor, 
    bgColor,
    ctaText,
    link,
    body
} = sectionData;

// Get background image
const backgroundImagePath = `/src/assets/images/${backgroundImage}`;
const imageImport = await import(backgroundImagePath);
const optimizedBackground = await getImage({src: imageImport.default});
---

<CTA
    layout="media"
    media={optimizedBackground.src}
    mediaType="image"
    text={ctaText}
    link={link}
    txtColor={txtColor}
    bgColor={bgColor}
>
    <Fragment set:html={body} />
</CTA>

