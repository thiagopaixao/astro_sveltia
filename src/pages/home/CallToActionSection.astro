---
// Import necessary components
import CTA from '../../components/CTA.astro';

interface Props {
    sectionData: {
        media: string;
        txtColor: string;
        bgColor: string;
        ctaText: string;
        link: {
            url: string;
            target: string;
            text: string;
        };
        body: string;
    }
}

const { sectionData } = Astro.props;
const { 
    media,
    txtColor, 
    bgColor,
    ctaText,
    link,
    body
} = sectionData;

// Get background image
const imgPath = `../../assets/images/${media}`;
const { default: img } = await import(imgPath, { assert: { type: 'image' } });
---

<CTA
    layout="media"
    media={img}
    mediaType="image"
    text={ctaText}
    link={link}
    txtColor={txtColor}
    bgColor={bgColor}
>
    <Fragment set:html={body} />
</CTA>

