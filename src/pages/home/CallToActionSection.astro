---
// Import necessary components and assets
import CTA from '../../components/CTA.astro';
import img from '../../assets/images/group-bg.png';

// Import markdown content
const content = await import('../../contents/home/CallToActionSection.md');
const { 
    ctaText, 
    link, 
    txtColor, 
    bgColor 
} = content.frontmatter;
---

<CTA
    layout="media"
    media={img}
    mediaType="image"
    text={ctaText}
    link={link}
    txtColor={txtColor}
    bgColor={bgColor}
>
    <Fragment set:html={content.compiledContent()} />
</CTA>

