---
// Import necessary components
import type { string } from 'astro:schema';
import Cta from '../../components/Cta.astro';

interface Props {
    sectionData: {
        layout: string;
        mediaType: string;
        media: string;
        txtColor: string;
        bgColor: string;
        ctaText: string;
        link: {
            url: string;
            target: string;
            text: string;
        };
        body: string;
    }
}

const { sectionData } = Astro.props;
const { 
    layout,
    mediaType,
    media,
    txtColor, 
    bgColor,
    ctaText,
    link,
    body
} = sectionData;

// Get background image
const imgPath = `../../assets/images/${media}`;
const { default: img } = await import(imgPath, { assert: { type: 'image' } });
---

<CTA
    layout={layout}
    media={img}
    mediaType={mediaType}
    text={ctaText}
    link={link}
    txtColor={txtColor}
    bgColor={bgColor}
>
    <Fragment set:html={body} />
</CTA>

