---
import Layout from "../layouts/Layout.astro";
import MapBox from "../components/MapBox.astro";
import IntroductionSection from "./home/IntroductionSection.astro";
import MainContentSection from "./home/MainContentSection.astro";
import CallToActionSection from "./home/CallToActionSection.astro";
import CardsCallSection from "./home/CardsCallSection.astro";
import MapTimelineSection from "./home/MapTimelineSection.astro";
import AdditionalCTASection from "./home/AdditionalCTASection.astro";
import AdditionalMapSection from "./home/AdditionalMapSection.astro";
import SupportSection from "./home/SupportSection.astro";
import MapSection from "./home/MapSection.astro";
---

<Layout title="Documental.xyz">
    <main>
        {/* MapBox section (always at the top) */}
        <MapBox />

        {/* Introduction section */}
        <IntroductionSection />

        {/* Main content section */}
        <MainContentSection />

        {/* Call to Action (CTA) section */}
        <CallToActionSection /> 

        {/* Additional CTA section with highlight */}
        <AdditionalCTASection />

        {/* Cards call section */}
        <CardsCallSection />

        {/* Map timeline section */}
        <MapTimelineSection />

        {/* Additional map section */}
        <AdditionalMapSection />

        <SupportSection />

        <MapSection />
    </main>

    <style lang="scss">
        main {
            background-color: var(--clr-bg, transparent);

            :global(> .spacer) {
                position: relative;
                background-color: inherit;
            }
        }
    </style>
</Layout>
---
import HomePage from './home/index.astro';
---

<HomePage />
