---
// Organize imports alphabetically and group by component type
import Columns from "../../components/Columns.astro";
import Group from "../../components/Group.astro";
import ImageBlock from "../../components/ImageBlock.astro";
import Map from "../../components/Map.astro";
import MapView from "../../components/MapView.astro";
import Spacer from "../../components/Spacer.astro";
import Text from "../../components/Text.astro";
import TextPlaceholder from "../../components/TextPlaceholder.astro";

// Keep image import at the end
import imgMap from "../../assets/images/map.png";
---

<Group txtColor="#364849" bgColor="#F0EAD9">
    <Columns>
        <Fragment slot="column-1">
            <Text>
                <TextPlaceholder />
            </Text>
        </Fragment>
        <Fragment slot="column-2">
            <ImageBlock src={imgMap}>
                Sed ut perspiciatis unde omnis iste natus error sit voluptatem
                accusantium doloremque laudantium, totam rem aperiam
            </ImageBlock>
        </Fragment>
    </Columns>
</Group>

<Map
