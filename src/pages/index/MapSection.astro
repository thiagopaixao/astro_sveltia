---
// Import necessary components
import Map from '../../components/Map.astro';
import Text from '../../components/Text.astro';
import MapView from '../../components/MapView.astro';
import Spacer from '../../components/Spacer.astro';
import TextPlaceholder from '../../components/TextPlaceholder.astro';
import { getEntry } from 'astro:content';

const mapSection = await getEntry('index', 'MapSection');
const { sections } = mapSection.data;
---

{sections.map((section) => (
    <Map
        columnAlign={section.columnAlign}
        floatingText={section.floatingText}
        txtColor={section.txtColor}
        bgColor={section.bgColor}
        mapView={section.mapView}
    >
        {section.content?.map((item) => {
            if (item.type === "text") {
                return <Text><Fragment set:html={item.html} /></Text>
            } else if (item.type === "spacer") {
                return <Spacer desktop={item.desktop} />
            }
        })}
        {section.views?.map((view) => (
            <MapView mapView={view.mapView} />
        ))}
    </Map>
))}
