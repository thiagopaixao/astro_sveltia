---
// Organize imports alphabetically
import ChartBar from '../../components/ChartBar.astro';
import Column from '../../components/Column.astro';
import Group from '../../components/Group.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import InnerColumns from '../../components/InnerColumns.astro';
import LogosGroup from '../../components/LogosGroup.astro';
import Text from '../../components/Text.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';

// Import images at the end
import img from '../../assets/images/group-bg.png';
import imgMap from '../../assets/images/map.png';
import logo from '../../assets/images/logo-1.jpg';
import logo2 from '../../assets/images/logo-2.png';
import logo3 from '../../assets/images/logo-3.png';

// Import markdown content
const content = await import('../../contents/index/SupportSection.md');
const { 
  txtColor, 
  bgColor, 
  chartBars, 
  logos: logosData, 
  videoEmbedUrl, 
  videoCaption 
} = content.frontmatter;

// Update image paths to use the imported logos
const logos = logosData.map((logoData, index) => ({
  image: [logo, logo2, logo3][index],
  link: {
    url: logoData.url,
    target: logoData.target,
    title: logoData.title,
  },
}));
---

<Group 
    txtColor={txtColor} 
    overlay="dark" 
    bgColor={bgColor} 
    imgBg={img.src}
>
    <Column>
        <LogosGroup 
            title="Apoio" 
            logos={logos} 
        />

        <ChartBar
            title="Sed ut perspiciatis unde omnis iste natus"
            notes="Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium"
            values={chartBars}
        />

        <VideoEmbed wide>
            <iframe
                width="560"
                height="315"
                src={videoEmbedUrl}
                title="YouTube video player"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
            ></iframe>
            <Fragment slot="caption">
                {videoCaption}
            </Fragment>
        </VideoEmbed>

        <Text>
            <Fragment set:html={content.compiledContent()} />
        </Text>

        <ImageBlock 
            src={imgMap} 
            alt="" 
            wide
        >
            Sed ut perspiciatis unde omnis iste natus error sit voluptatem
            accusantium
        </ImageBlock>
    </Column>
</Group>
