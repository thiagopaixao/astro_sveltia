---
const { Component, props } = Astro.props;
const { src, alt, wide, description } = props;


let img;
if (src) {
  img = `${import.meta.env.BASE_URL}/uploads/${src}`;
}

const componentData = {
    src: img,
    alt: alt || "",
    wide: wide || false,
    description
};
---

<Component {...componentData}>
    <slot />
    {description}
</Component>
