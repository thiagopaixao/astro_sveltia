---
const { Component, props } = Astro.props;
const { logosGroupArr = []} = props;

const componentData = {
    title: "Apoio",
    logos: props.logos
};


// Atualiza o array de cards substituindo a imagem original por `thumb` localizada em public/uploads
const updatedlogosGroupArr = logosGroupArr.map(logos => {
  let updatedImg = { ...logos.image };
    if (updatedImg.src) {
        updatedImg.src = `${import.meta.env.BASE_URL}${logos.image.src}`;
        updatedImg.width = '100%';
        updatedImg.height = '100%';
    }
  return {
    ...logos,
    image: updatedImg

  };
---

<Component logos={updatedlogosGroupArr}>
    <slot />
</Component>