---
import logo from '../assets/images/logo-1.jpg';
import logo2 from '../assets/images/logo-2.png';
import logo3 from '../assets/images/logo-3.png';

const { Component, props } = Astro.props;

const logos = [
    {
        image: `${import.meta.env.BASE_URL}/uploads/logo-1.jpg`,
        link: {
            url: '#',
            target: '_blank',
            title: 'Lorem Logo',
        },
    },
    {
        image: `${import.meta.env.BASE_URL}/uploads/logo-2.png`,
        link: {
            url: '#',
            target: '_self',
            title: 'Ipsum dolor logo',
        },
    },
    {
        image: `${import.meta.env.BASE_URL}/uploads/logo-3.png`,
        link: {
            url: '#',
            target: '_blank',
            title: 'Sit amet lorem logo',
        },
    },
];

const componentData = {
    title: "Apoio",
    logos
};
---

<Component {...componentData}>
    <slot />
</Component>
